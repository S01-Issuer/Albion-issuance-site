# Metaboard Admin
# Production: 0x4E5Bd3Cf829010280F76754B49921d4e1448B8Cf
# Development/Preview: 0xD2843D9E7738d46D90CB6Dff8D6C83db58B9c165
PUBLIC_METABOARD_ADMIN=0xD2843D9E7738d46D90CB6Dff8D6C83db58B9c165
PRIVATE_HYPERSYNC_API_KEY=
# Wallet Connect Project Id
PUBLIC_WALLETCONNECT_ID=
# Alchemy API key for reliable Base RPC (avoids public RPC rate limits)
# Get one at https://dashboard.alchemy.com
PUBLIC_ALCHEMY_API_KEY=
PRIVATE_PINATA_JWT=
PUBLIC_PINATA_GATEWAY_URL=
PRIVATE_PINATA_GATEWAY_KEY=
# Payout email alerts (MailerLite). Optional — the UI hides the feature when unset.
# Setup in MailerLite: create a group (e.g. "Payout Alerts") and a TEXT custom
# field named `wallet_addresses`, then paste the API token + group id here.
# IMPORTANT: enable MailerLite double opt-in for this group. The subscribe API
# verifies the WALLET signature but cannot verify the EMAIL belongs to the
# requester, so without double opt-in someone could subscribe a third party's
# address. Double opt-in makes MailerLite send a confirmation the real owner
# must click before any payout alert is delivered.
PRIVATE_MAILERLITE_API_KEY=
PRIVATE_MAILERLITE_GROUP_ID=
# Optional dedicated server-side RPC for signature verification (defaults to
# Alchemy via PUBLIC_ALCHEMY_API_KEY, then the public Base RPC).
PRIVATE_BASE_RPC_URL=